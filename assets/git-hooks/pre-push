#!/bin/sh
# agentic-vault git 원격 정책 가드 — 로컬 전용 기계 강제
#
# 개인 지식 볼트에는 기밀·개인정보 노트가 축적될 수 있다.
# 이 훅은 사용자가 기밀 여부를 점검하고 명시적으로 결정하기 전까지
# 모든 원격 push를 차단한다(로컬 전용 권고 — README '한계' 참조).
#
# 정당한 원격 배포: 기밀 제거 브랜치를 만든 뒤 --no-verify로 명시 우회.
# 훅 전체 비활성화: git config --unset core.hooksPath

echo "" >&2
echo "🚫 차단됨 — 이 볼트는 로컬 전용입니다(agentic-vault 기본 정책)." >&2
echo "   볼트에는 기밀·개인정보 노트가 포함될 수 있습니다. push 전에 기밀 여부를 점검하세요." >&2
echo "   원격 배포가 정말 필요하면 기밀 제거 브랜치를 만들고 --no-verify로 명시 우회하세요." >&2
echo "" >&2
exit 1
